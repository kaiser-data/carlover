# =============================================================
# Carlover — Automotive Assistant Backend
# Copy this file to .env and fill in your values.
# =============================================================

# -------------------------------------------------------------
# Featherless AI — https://api.featherless.ai
# Models MUST support JSON/structured output mode.
# Recommended: Llama-3.1 family for text, Qwen2-VL for vision.
# -------------------------------------------------------------
FEATHERLESS_API_KEY=your_featherless_api_key_here
FEATHERLESS_BASE_URL=https://api.featherless.ai/v1

# Fast model for intent classification + entity extraction
FEATHERLESS_MODEL_ORCHESTRATOR=Qwen/Qwen2.5-14B-Instruct

# Capable model for answer synthesis + complex reasoning
FEATHERLESS_MODEL_REASONING=Qwen/Qwen2.5-72B-Instruct

# Vision-capable model for image analysis (MUST support image input)
FEATHERLESS_MODEL_VISION=Qwen/Qwen2.5-VL-72B-Instruct

# Model for final response generation
FEATHERLESS_MODEL_RESPONSE=Qwen/Qwen2.5-72B-Instruct

# LLM request settings
LLM_TIMEOUT=30
LLM_MAX_RETRIES=3

# -------------------------------------------------------------
# Supabase — https://supabase.com
# Use service role key for backend access.
# -------------------------------------------------------------
SUPABASE_URL=https://your-project-id.supabase.co
SUPABASE_KEY=your_supabase_service_role_key_here

# -------------------------------------------------------------
# Vehicle detection thresholds
# MIN_CONFIDENCE: below this value → ask user for clarification
# AMBIGUITY_GAP: if gap between top-2 candidates < this → also ask
# -------------------------------------------------------------
VEHICLE_DETECTION_MIN_CONFIDENCE=0.70
VEHICLE_DETECTION_AMBIGUITY_GAP=0.20

# -------------------------------------------------------------
# Provider selection
# ADAC_PROVIDER: "mock" uses built-in mock data; "real" requires real credentials
# MCP_ENABLED: set to "true" to activate optional MCP tool layer
# -------------------------------------------------------------
ADAC_PROVIDER=mock
MCP_ENABLED=false

# -------------------------------------------------------------
# Daytona — https://app.daytona.io
# Used for sandbox deployment and the Sandbox Agent.
# Get your API key at: https://app.daytona.io/dashboard/keys
# -------------------------------------------------------------
DAYTONA_API_KEY=your_daytona_api_key_here
DAYTONA_API_URL=https://app.daytona.io/api

# -------------------------------------------------------------
# Application settings
# -------------------------------------------------------------
DEBUG=false
LOG_LEVEL=INFO
APP_VERSION=0.1.0
